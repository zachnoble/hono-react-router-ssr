{
	"name": "hono-react-router-ssr",
	"scripts": {
		"prepare": "husky",
		"setup": "concurrently -n backend,frontend -c cyan,magenta \"bun run setup:backend\" \"bun run setup:frontend\"",
		"setup:backend": "cd backend && bun install",
		"setup:frontend": "cd frontend && bun install",
		"lint": "oxlint .",
		"lint:fix": "oxlint --fix-dangerously .",
		"format": "oxfmt .",
		"format:check": "oxfmt --check .",
		"fix": "oxfmt . && oxlint --fix-dangerously .",
		"fix:backend": "oxfmt backend && oxlint --fix-dangerously backend",
		"fix:frontend": "oxfmt frontend && oxlint --fix-dangerously frontend"
	},
	"devDependencies": {
		"concurrently": "^9.2.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"oxfmt": "latest",
		"oxlint": "latest",
		"oxlint-tsgolint": "^0.21.1"
	}
}
