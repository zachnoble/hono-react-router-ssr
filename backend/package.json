{
	"name": "backend",
	"scripts": {
		"dev": "bun run --hot src/cmd/http/index.ts",
		"build": "bun build src/cmd/http/index.ts --target=bun --sourcemap=inline --outdir=dist --minify",
		"start": "bun run dist/index.js",
		"generate": "bun run --bun drizzle-kit generate --name",
		"migrate": "bun run --bun drizzle-kit migrate",
		"test": "bun --env-file=.env.test test",
		"typecheck": "tsgo --noEmit"
	},
	"dependencies": {
		"@hono/zod-validator": "^0.7.6",
		"better-auth": "^1.6.9",
		"drizzle-orm": "^0.44.7",
		"hono": "^4.12.16",
		"nanoid": "^5.1.11",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"postgres": "^3.4.9",
		"resend": "^6.12.2",
		"zod": "^4.4.2"
	},
	"devDependencies": {
		"@types/bun": "^1.3.13",
		"@typescript/native-preview": "latest",
		"drizzle-kit": "^0.31.10",
		"typescript": "^5.9.3"
	}
}
