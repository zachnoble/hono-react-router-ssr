# Environment
NODE_ENV=development

# Port
PORT=8080

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Signature for signing cookies
SIGNATURE=signature

# DB
DB_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Cache
CACHE_HOST=localhost
CACHE_PORT=6379

# Email with Resend
EMAIL_API_KEY=resend-api-key
EMAIL_FROM_ADDRESS=email-from@domain.com

# GCP
GCP_PROJECT_ID=google-project-id
GCP_RECAPTCHA_SITE_KEY=google-recaptcha-site-key
GCP_RECAPTCHA_API_KEY=google-recaptcha-api-key
